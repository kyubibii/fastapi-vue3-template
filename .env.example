# ================================
# Application
# ================================
APP_ENV=development
# 接口中无时区 datetime 的墙钟解释；留空则使用运行本机/容器的系统时区。例：Asia/Shanghai
APP_TIMEZONE=
PROJECT_NAME="Enterprise FastAPI Template"
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ================================
# Database (MySQL)
# ================================
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=changeme
MYSQL_DB=appdb

# ================================
# First Superuser
# ================================
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=Admin@123456

# ================================
# CORS
# ================================
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
FRONTEND_HOST=http://localhost:5173

# ================================
# Email (MailHog for dev)
# ================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME="Enterprise App"

# ================================
# Audit Log
# ================================
# Set to true to also write audit logs to a JSON Lines file
LOG_TO_FILE=false
LOG_FILE_PATH=/var/log/app/audit.jsonl

# ================================
# Sentry (production only)
# ================================
SENTRY_DSN=
ENVIRONMENT=development

# ================================
# Startup automation
# ================================
AUTO_MIGRATE_ON_STARTUP=true
AUTO_SEED_ON_STARTUP=true
AUTO_CREATE_TABLES_IF_NO_MIGRATIONS=true
